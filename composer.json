{
    "name": "phapr/phapr",
    "description": "Phapr is an expressive PHP project build system",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "build"
    ],
    "homepage": "https://panlatent.com/phapr",
    "authors": [
        {
            "name": "panlatent",
            "email": "panlatent@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.1",
        "guzzlehttp/guzzle": "^6.3",
        "illuminate/container": "~5.6",
        "monolog/monolog": "~1.20",
        "phpdocumentor/reflection-docblock": "^4.0",
        "symfony/console": "^4.1",
        "symfony/css-selector": "^4.1",
        "symfony/dom-crawler": "^4.1",
        "symfony/expression-language": "^4.1",
        "symfony/filesystem": "~4.1",
        "symfony/finder": "^4.1",
        "symfony/process": "^4.1",
        "symfony/event-dispatcher": "^4.1",
        "symfony/yaml": "^4.1"
    },
    "require-dev": {
        "codeception/codeception": "^2.4",
        "php-coveralls/php-coveralls": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Phapr\\": "src/"
        },
        "files": [
            "src/Helper/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Phapr\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1.x-dev"
        }
    }
}
